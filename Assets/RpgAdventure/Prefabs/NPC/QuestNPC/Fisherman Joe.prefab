  dialog:
    welcomeText: Hello there. Who are you? This is a bad place for newcomers.
    dialogQueries:
    - text: Yes, I'm new Warden and I'm on my mission to get to the village.
      answer:
        text: 'Really? Amazing news! Do you have any idea what''s going here? No
          ? So I will tell you something. This place is like fishing net with too
          many predators in and out this net and with too less fishes inside the
          net. '
        forceDialogQuit: 0
        questId: 
      isAsked: 0
      isAlwaysAsked: 0
    - text: Do you need any help?
      answer:
        text: In fishing no, but could you Mr Warden get rid of these two bandits
          that waiting near road for new victims? I'm old and don't have nothing
          interesting for them. Sometimes i give them fish so they leave me alone
          and I can go to the village
        forceDialogQuit: 0
        questId: q-1
      isAsked: 0
      isAlwaysAsked: 0
    - text: Goodbye
      answer:
        text: See you
        forceDialogQuit: 1
        questId: 
      isAsked: 0
      isAlwaysAsked: 1
