  quest:
    uid: 
    title: 
    description: 
    experience: 0
    gold: 0
    amount: 0
    targets: []
    talkTo: 
    explore: {x: 0, y: 0, z: 0}
    questGiver: 
    type: 0
  dialog:
    welcomeText: Hello there Stranger. What's brings you here to these forgotten
      by everyone and everything place?
    dialogQueries:
    - text: I'm a Warden. I was sent here to check what's wrong here. I see there
        are many problems. Where should I start ?
      answer:
        text: Warden? Here?! That's ridiculous !! Aww... You serious? Okay,okay,
          got it. I'm guard Robert. You have no idea what bad luck you have to be
          here now. I feel sorry for you. Okay, got to buissnes. Talk to villagers,
          they have many issues with everything here. For me, just kill as many bandits
          as you could before they kill you. Ha! Just kidding. I hope you will survive.
          Just get rid of some outlaws here and there and I will be more then happy.
        forceDialogQuit: 0
        questId: q-6
      isAsked: 0
      isAlwaysAsked: 0
    - text: Got it. I will be going.
      answer:
        text: Take care and good luck.
        forceDialogQuit: 1
        questId: 
      isAsked: 0
      isAlwaysAsked: 1
